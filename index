<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MyShopSavings - Smart Product Finder</title>
  <style>
    :root {
      --bg: #07111f;
      --panel: rgba(255, 255, 255, 0.1);
      --panel-strong: rgba(255, 255, 255, 0.16);
      --text: #f8fbff;
      --muted: #abc0d8;
      --green: #36f0a0;
      --teal: #28d8ff;
      --yellow: #ffd166;
      --pink: #ff5d8f;
      --shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, "Segoe UI", system-ui, -apple-system, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 12% 14%, rgba(54, 240, 160, 0.28), transparent 30%),
        radial-gradient(circle at 80% 8%, rgba(40, 216, 255, 0.24), transparent 32%),
        radial-gradient(circle at 50% 90%, rgba(255, 93, 143, 0.2), transparent 38%),
        linear-gradient(135deg, #06101d 0%, #0b1c34 52%, #09111f 100%);
      overflow-x: hidden;
    }

    .glow {
      position: fixed;
      border-radius: 999px;
      filter: blur(4px);
      opacity: 0.45;
      pointer-events: none;
      animation: float 16s ease-in-out infinite;
      z-index: -1;
    }

    .glow:nth-child(1) { width: 160px; height: 160px; left: 6%; top: 55%; background: var(--green); }
    .glow:nth-child(2) { width: 110px; height: 110px; right: 8%; top: 35%; background: var(--teal); animation-delay: 3s; }
    .glow:nth-child(3) { width: 90px; height: 90px; left: 42%; top: 14%; background: var(--yellow); animation-delay: 6s; }

    @keyframes float {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-26px) scale(1.08); }
    }

    .wrap {
      width: min(1180px, 92vw);
      margin: 0 auto;
      padding: 42px 0 56px;
    }

    header {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 28px;
      align-items: center;
      min-height: 420px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 999px;
      color: #d8ffef;
      background: rgba(54, 240, 160, 0.12);
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    h1 {
      margin: 18px 0 14px;
      font-size: clamp(2.55rem, 6vw, 5.35rem);
      line-height: 0.94;
      letter-spacing: -0.07em;
    }

    h1 span {
      display: block;
      background: linear-gradient(90deg, var(--green), var(--teal), #ffffff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      max-width: 650px;
      color: var(--muted);
      font-size: clamp(1rem, 2vw, 1.2rem);
      line-height: 1.65;
    }

    .search-card, .panel {
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: linear-gradient(145deg, rgba(255,255,255,0.16), rgba(255,255,255,0.07));
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
      border-radius: 30px;
    }

    .search-card {
      padding: 24px;
      transform: rotate(1.5deg);
    }

    .search-card h2, .panel h2 {
      margin: 0 0 12px;
      font-size: 1.25rem;
    }

    label {
      display: block;
      margin: 16px 0 8px;
      color: #d9e7f7;
      font-weight: 700;
    }

    textarea, input, select {
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 18px;
      padding: 14px 16px;
      color: var(--text);
      background: rgba(0, 0, 0, 0.24);
      font: inherit;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    textarea:focus, input:focus, select:focus {
      border-color: rgba(54, 240, 160, 0.8);
      box-shadow: 0 0 0 4px rgba(54, 240, 160, 0.13);
    }

    .controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    button {
      border: 0;
      border-radius: 18px;
      padding: 14px 18px;
      color: #03121b;
      background: linear-gradient(90deg, var(--green), var(--teal));
      font: inherit;
      font-weight: 900;
      cursor: pointer;
      transition: transform 0.2s, filter 0.2s;
    }

    button:hover { transform: translateY(-2px); filter: brightness(1.07); }
    button:active { transform: translateY(0) scale(0.98); }

    .note {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 18px;
    }

    .stat {
      padding: 14px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.1);
    }

    .stat strong {
      display: block;
      color: var(--green);
      font-size: 1.45rem;
    }

    .layout {
      display: grid;
      grid-template-columns: 0.78fr 1.22fr;
      gap: 22px;
      align-items: start;
    }

    .panel { padding: 22px; }

    .deal {
      position: relative;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 16px;
      align-items: center;
      margin-top: 14px;
      padding: 16px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.09);
    }

    .deal.best {
      border-color: rgba(54, 240, 160, 0.62);
      background: linear-gradient(145deg, rgba(54, 240, 160, 0.18), rgba(40, 216, 255, 0.09));
    }

    .product-icon {
      display: grid;
      place-items: center;
      width: 58px;
      height: 58px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 1.75rem;
    }

    .deal h3 { margin: 0 0 5px; }
    .deal p { margin: 0; color: var(--muted); }

    .price {
      text-align: right;
      min-width: 110px;
    }

    .price strong {
      display: block;
      color: #fff;
      font-size: 1.65rem;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
      padding: 6px 10px;
      border-radius: 999px;
      color: #06111d;
      background: var(--yellow);
      font-size: 0.8rem;
      font-weight: 900;
    }

    .meter {
      height: 10px;
      margin-top: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.12);
    }

    .meter span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--green), var(--teal));
    }

    .steps {
      display: grid;
      gap: 12px;
      margin-top: 10px;
    }

    .step {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.09);
      color: var(--muted);
    }

    .step strong { color: #fff; }


    .retailers {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 14px 0 4px;
    }

    .retailer-chip {
      padding: 7px 10px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      color: #e9f7ff;
      background: rgba(255, 255, 255, 0.08);
      font-size: 0.83rem;
      font-weight: 800;
    }

    .source {
      margin: 12px 0 0;
      padding: 12px 14px;
      border: 1px solid rgba(54, 240, 160, 0.22);
      border-radius: 16px;
      color: #d8ffef;
      background: rgba(54, 240, 160, 0.1);
    }

    .deal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .deal-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 36px;
      padding: 8px 12px;
      border-radius: 999px;
      color: #03121b;
      background: linear-gradient(90deg, var(--green), var(--teal));
      font-size: 0.86rem;
      font-weight: 900;
      text-decoration: none;
      transition: transform 0.2s, filter 0.2s;
    }

    .deal-actions a.secondary {
      color: #f8fbff;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.14);
    }

    .deal-actions a:hover { transform: translateY(-2px); filter: brightness(1.08); }

    @media (max-width: 840px) {
      header, .layout { grid-template-columns: 1fr; }
      .search-card { transform: none; }
      .stats, .controls { grid-template-columns: 1fr; }
      .deal { grid-template-columns: 1fr; }
      .price { text-align: left; }
    }
  </style>
</head>
<body>
  <div class="glow"></div>
  <div class="glow"></div>
  <div class="glow"></div>

  <main class="wrap">
    <header>
      <section>
        <span class="eyebrow">🛒 MyShopSavings deal scout</span>
        <h1>Paste a link. <span>Find the best product.</span></h1>
        <p class="hero-copy">
          MyShopSavings understands product names plus Amazon, Walmart, Target, Best Buy, eBay, and Etsy links. It turns them into
          retailer search shortcuts and a clear buying recommendation across price, shipping, coupons, ratings, returns, and seller trust.
        </p>
        <div class="stats" aria-label="shopping comparison highlights">
          <div class="stat"><strong>37%</strong><span>sample savings found</span></div>
          <div class="stat"><strong>6+</strong><span>retailers supported</span></div>
          <div class="stat"><strong>1</strong><span>best-value pick</span></div>
        </div>
      </section>

      <section class="search-card" aria-labelledby="finder-title">
        <h2 id="finder-title">Try the savings finder</h2>
        <label for="product-input">Product link or name</label>
        <textarea id="product-input" rows="4" placeholder="Example: wireless headphones, standing desk, https://www.amazon.com/dp/B08N5WRWNW, or a Walmart/Target/Best Buy/eBay link"></textarea>
        <div class="controls">
          <div>
            <label for="priority">What matters most?</label>
            <select id="priority">
              <option value="value">Best overall value</option>
              <option value="price">Lowest price</option>
              <option value="rating">Highest rating</option>
            </select>
          </div>
          <div>
            <label for="budget">Max budget</label>
            <input id="budget" type="number" min="10" value="180" />
          </div>
        </div>
        <button id="find-button" type="button">Find My Best Deal</button>
        <p class="note">Demo compares major retailer options and gives one-click searches. Live checkout prices still need retailer confirmation.</p>
      </section>
    </header>

    <section class="layout">
      <aside class="panel">
        <h2>How it works</h2>
        <div class="steps">
          <div class="step"><strong>1. Read your product</strong><br />Accepts plain names, messy notes, Amazon links, Walmart links, Target links, Best Buy links, eBay links, and more.</div>
          <div class="step"><strong>2. Compare major retailers</strong><br />Builds Amazon, Walmart, Target, Best Buy, eBay, Etsy, and Google Shopping searches from the same product.</div>
          <div class="step"><strong>3. Explain the winner</strong><br />Ranks options with price, shipping, coupon, rating, seller quality, return, and marketplace risk signals.</div>
        </div>
      </aside>

      <section class="panel" aria-live="polite">
        <h2>Recommended matches</h2>
        <p class="note" id="summary">Enter a product or paste a link, then run the finder.</p>
        <div class="retailers" aria-label="supported retailers">
          <span class="retailer-chip">Amazon</span>
          <span class="retailer-chip">Walmart</span>
          <span class="retailer-chip">Target</span>
          <span class="retailer-chip">Best Buy</span>
          <span class="retailer-chip">eBay</span>
          <span class="retailer-chip">Etsy</span>
          <span class="retailer-chip">Google Shopping</span>
        </div>
        <div id="source-details" class="source"></div>
        <div id="results"></div>
      </section>
    </section>
  </main>

  <script>
    const input = document.querySelector("#product-input");
    const priority = document.querySelector("#priority");
    const budget = document.querySelector("#budget");
    const button = document.querySelector("#find-button");
    const results = document.querySelector("#results");
    const summary = document.querySelector("#summary");
    const sourceDetails = document.querySelector("#source-details");

    const retailers = [
      {
        name: "Amazon",
        icon: "🟧",
        domains: ["amazon.com", "amzn.to"],
        shipping: 0,
        rating: 4.6,
        returns: "30-day returns",
        trust: 94,
        coupon: 8,
        priceFactor: 0.88,
        risk: 6,
        searchUrl: query => `https://www.amazon.com/s?k=${encodeURIComponent(query)}`
      },
      {
        name: "Walmart",
        icon: "⭐",
        domains: ["walmart.com"],
        shipping: 0,
        rating: 4.4,
        returns: "90-day returns on many items",
        trust: 91,
        coupon: 5,
        priceFactor: 0.84,
        risk: 8,
        searchUrl: query => `https://www.walmart.com/search?q=${encodeURIComponent(query)}`
      },
      {
        name: "Target",
        icon: "🎯",
        domains: ["target.com"],
        shipping: 6,
        rating: 4.5,
        returns: "90-day returns on most items",
        trust: 92,
        coupon: 7,
        priceFactor: 0.9,
        risk: 7,
        searchUrl: query => `https://www.target.com/s?searchTerm=${encodeURIComponent(query)}`
      },
      {
        name: "Best Buy",
        icon: "🔵",
        domains: ["bestbuy.com"],
        shipping: 0,
        rating: 4.7,
        returns: "15-day standard returns",
        trust: 95,
        coupon: 4,
        priceFactor: 0.94,
        risk: 4,
        searchUrl: query => `https://www.bestbuy.com/site/searchpage.jsp?st=${encodeURIComponent(query)}`
      },
      {
        name: "eBay",
        icon: "🟢",
        domains: ["ebay.com"],
        shipping: 7,
        rating: 4.2,
        returns: "seller return policies vary",
        trust: 82,
        coupon: 12,
        priceFactor: 0.78,
        risk: 15,
        searchUrl: query => `https://www.ebay.com/sch/i.html?_nkw=${encodeURIComponent(query)}`
      },
      {
        name: "Etsy",
        icon: "🧡",
        domains: ["etsy.com"],
        shipping: 5,
        rating: 4.6,
        returns: "shop return policies vary",
        trust: 84,
        coupon: 6,
        priceFactor: 0.96,
        risk: 13,
        searchUrl: query => `https://www.etsy.com/search?q=${encodeURIComponent(query)}`
      }
    ];

    const shoppingSearchUrl = query => `https://www.google.com/search?tbm=shop&q=${encodeURIComponent(query)}`;

    function escapeHtml(value) {
      return String(value).replace(/[&<>"]/g, character => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;"
      }[character]));
    }

    function normalizeHost(hostname) {
      return hostname.replace(/^www\./, "").toLowerCase();
    }

    function wordsFromPath(pathname) {
      const skip = new Set(["dp", "gp", "product", "products", "itm", "ip", "p", "site", "shop", "listing"]);
      return pathname
        .split("/")
        .filter(Boolean)
        .filter(part => !skip.has(part.toLowerCase()))
        .filter(part => !/^[A-Z0-9]{8,16}$/i.test(part))
        .join(" ")
        .replace(/[-_+]/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }

    function extractAmazonProduct(url) {
      const asinMatch = url.pathname.match(/\/(?:dp|gp\/product)\/([A-Z0-9]{10})/i);
      const slug = wordsFromPath(url.pathname);
      return {
        id: asinMatch?.[1] || "",
        query: slug || asinMatch?.[1] || url.searchParams.get("k") || "Amazon product"
      };
    }

    function parseProduct(raw) {
      const trimmed = raw.trim();
      if (!trimmed) {
        return { query: "everyday product", source: "Product name", retailer: null, id: "" };
      }

      if (/^https?:\/\//i.test(trimmed)) {
        try {
          const url = new URL(trimmed);
          const host = normalizeHost(url.hostname);
          const retailer = retailers.find(store => store.domains.some(domain => host === domain || host.endsWith(`.${domain}`)));
          let product = { query: wordsFromPath(url.pathname) || host, id: "" };

          if (retailer?.name === "Amazon") product = extractAmazonProduct(url);
          if (url.searchParams.get("q")) product.query = url.searchParams.get("q");
          if (url.searchParams.get("searchTerm")) product.query = url.searchParams.get("searchTerm");
          if (url.searchParams.get("st")) product.query = url.searchParams.get("st");
          if (url.searchParams.get("_nkw")) product.query = url.searchParams.get("_nkw");

          return {
            query: product.query.replace(/\s+/g, " ").trim() || host,
            source: retailer ? `${retailer.name} link` : `${host} link`,
            retailer,
            id: product.id,
            originalUrl: trimmed
          };
        } catch {
          return { query: trimmed, source: "Product name", retailer: null, id: "" };
        }
      }

      return { query: trimmed, source: "Product name", retailer: null, id: "" };
    }

    function buildDeals(product) {
      const base = Math.max(35, Math.min(Number(budget.value) || 180, 999));
      return retailers.map((retailer, index) => {
        const matchedRetailerBoost = product.retailer?.name === retailer.name ? 10 : 0;
        const price = Math.round(base * (retailer.priceFactor + index * 0.015));
        const total = Math.max(1, price + retailer.shipping - retailer.coupon);
        const ratingBoost = priority.value === "rating" ? retailer.rating * 12 : retailer.rating * 6;
        const priceBoost = priority.value === "price" ? (base - total) * 0.75 : (base - total) * 0.48;
        const valueScore = Math.round(priceBoost + ratingBoost + retailer.trust * 0.3 + retailer.coupon * 1.15 - retailer.risk + matchedRetailerBoost);
        return {
          ...retailer,
          title: `${product.query} at ${retailer.name}`,
          total,
          price,
          valueScore: Math.max(1, valueScore),
          searchUrl: retailer.searchUrl(product.query)
        };
      }).sort((a, b) => b.valueScore - a.valueScore || a.total - b.total);
    }

    function render() {
      const product = parseProduct(input.value);
      const deals = buildDeals(product);
      const best = deals[0];
      const savings = Math.max(...deals.map(deal => deal.total)) - best.total;
      const safeQuery = escapeHtml(product.query);
      const sourceText = `${product.source}${product.id ? ` · ASIN ${product.id}` : ""}`;

      summary.textContent = `Best match for “${product.query}”: ${best.name}, with an estimated $${savings} saved versus the priciest match.`;
      sourceDetails.innerHTML = `Detected: <strong>${escapeHtml(sourceText)}</strong>. Comparing Amazon, Walmart, Target, Best Buy, eBay, Etsy, and Google Shopping searches for <strong>${safeQuery}</strong>.`;
      results.innerHTML = deals.map((deal, index) => `
        <article class="deal ${index === 0 ? "best" : ""}">
          <div class="product-icon" aria-hidden="true">${index === 0 ? "🏆" : deal.icon}</div>
          <div>
            <h3>${escapeHtml(deal.title)}</h3>
            <p>${escapeHtml(deal.name)} · ${deal.rating}★ · ${escapeHtml(deal.returns)} · $${deal.coupon} coupon estimate · $${deal.shipping} shipping estimate</p>
            <div class="meter" aria-label="value score ${deal.valueScore}"><span style="width:${Math.min(deal.valueScore, 100)}%"></span></div>
            <div class="deal-actions">
              <a href="${escapeHtml(deal.searchUrl)}" target="_blank" rel="noopener noreferrer">Search ${escapeHtml(deal.name)}</a>
              ${index === 0 ? `<a class="secondary" href="${escapeHtml(shoppingSearchUrl(product.query))}" target="_blank" rel="noopener noreferrer">Compare on Google Shopping</a>` : ""}
            </div>
            ${index === 0 ? "<span class='badge'>Best MyShopSavings pick</span>" : ""}
          </div>
          <div class="price">
            <strong>$${deal.total}</strong>
            <span>estimated total</span>
          </div>
        </article>
      `).join("");
    }

    button.addEventListener("click", render);
    input.value = "https://www.amazon.com/dp/B08N5WRWNW";
    render();
  </script>
</body>
</html>
